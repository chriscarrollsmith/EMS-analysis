{
  "source_url": "https://data.cityofnewyork.us/api/views/76xm-jjuj/files/5f77cf01-4e52-443b-a718-a3e6567e83f2?download=true&filename=EMS_incident_dispatch_data_description.xlsx",
  "sheets": [
    {
      "name": "EMS File Description",
      "records": [
        {
          "field_name": "CAD_INCIDENT_ID",
          "field_description": "An incident identifier comprising the julian date and a 4 character sequence number starting at 1 each day."
        },
        {
          "field_name": "INCIDENT_DATETIME",
          "field_description": "The date and time the incident was created in the dispatch system"
        },
        {
          "field_name": "INITIAL_CALL_TYPE *",
          "field_description": "The call type assigned at the time of incident creation.",
          "column_2": "Note: The call type does not reflect the actual condition of the patient.  It is a determination based on information obtained from the caller for the purpose of defining severity and resource allocation."
        },
        {
          "field_name": "INITIAL_SEVERITY_LEVEL_CODE",
          "field_description": "The segment(priority) assigned at the time of incident creation."
        },
        {
          "field_name": "FINAL_CALL_TYPE *",
          "field_description": "The call type at the time the incident closes.",
          "column_2": "Note: The call type does not reflect the actual condition of the patient.  It is a determination based on information obtained from the caller for the purpose of defining severity and resource allocation. The call type does not change based on the findings of the on scene ambulance crew."
        },
        {
          "field_name": "FINAL_SEVERITY_LEVEL_CODE",
          "field_description": "The segment(priority) assigned at the time the incident closes."
        },
        {
          "field_name": "FIRST_ASSIGNMENT_DATETIME",
          "field_description": "The date and time the first unit is assigned."
        },
        {
          "field_name": "VALID_DISPATCH_RSPNS_TIME_INDC",
          "field_description": "Indicates that the components comprising the calculation of the DISPATCH_RESPONSE_SECONDS_QY are valid."
        },
        {
          "field_name": "DISPATCH_RESPONSE_SECONDS_QY",
          "field_description": "The time elapsed in seconds between the incident_datetime and the first_assignment_datetime."
        },
        {
          "field_name": "FIRST_ACTIVATION_DATETIME",
          "field_description": "The date and time the first unit gives the signal that it is enroute to the location of the incident."
        },
        {
          "field_name": "FIRST_ON_SCENE_DATETIME",
          "field_description": "The date and time the first unit signals that it has arrived at the location of the incident."
        },
        {
          "field_name": "VALID_INCIDENT_RSPNS_TIME_INDC",
          "field_description": "Indicates that the components comprising the calculation of the INCIDENT_RESPONSE_SECONDS_QY are valid."
        },
        {
          "field_name": "INCIDENT_RESPONSE_SECONDS_QY",
          "field_description": "The time elapsed in seconds between the incident_datetime and the first_on_scene_datetime."
        },
        {
          "field_name": "INCIDENT_TRAVEL_TM_SECONDS_QY",
          "field_description": "The time elapsed in seconds between the first_assignment_datetime and the first_on_scene_datetime."
        },
        {
          "field_name": "FIRST_TO_HOSP_DATETIME",
          "field_description": "The date and time the first unit gives the signal that it is enroute to the hospital."
        },
        {
          "field_name": "FIRST_HOSP_ARRIVAL_DATETIME",
          "field_description": "The date and time the first unit signals that it has arrived at the hospital."
        },
        {
          "field_name": "INCIDENT_CLOSE_DATETIME",
          "field_description": "The date and time the incident closes in the dispatch system."
        },
        {
          "field_name": "HELD_INDICATOR",
          "field_description": "Indicates that for some reason a unit could not be assigned immediately"
        },
        {
          "field_name": "INCIDENT_DISPOSITION_CODE ",
          "field_description": "A code indicating the final outcome of the incident. See incident dispositions."
        },
        {
          "field_name": "BOROUGH",
          "field_description": "The borough of the incident location."
        },
        {
          "field_name": "INCIDENT_DISPATCH_AREA",
          "field_description": "The dispatch area of the incident."
        },
        {
          "field_name": "ZIPCODE",
          "field_description": "The zip code of the incident."
        },
        {
          "field_name": "POLICEPRECINCT",
          "field_description": "The police precinct of the incident."
        },
        {
          "field_name": "CITYCOUNCILDISTRICT",
          "field_description": "The city council district."
        },
        {
          "field_name": "COMMUNITYDISTRICT",
          "field_description": "The community district."
        },
        {
          "field_name": "COMMUNITYSCHOOLDISTRICT",
          "field_description": "The community school district."
        },
        {
          "field_name": "CONGRESSIONALDISTRICT ",
          "field_description": "The congressional district."
        },
        {
          "field_name": "REOPEN_INDICATOR",
          "field_description": "Indicates that at some point the incident was closed but then reopened."
        },
        {
          "field_name": "SPECIAL_EVENT_INDICATOR",
          "field_description": "Indicates that the incident was a special event such as the NYC Marathon."
        },
        {
          "field_name": "STANDBY_INDICATOR",
          "field_description": "Indicates that the units were assigned to stand by incase they were needed."
        },
        {
          "field_name": "TRANSFER_INDICATOR",
          "field_description": "Indicates that the incident was created for the  transportation of a patient from one facility (ie a hospital or nursing home) to another."
        }
      ]
    },
